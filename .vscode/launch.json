{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Playwright Tests",
            "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
            "args": ["test", "--debug"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PWDEBUG": "1"
            }
        }
    ]
}